---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Services | Novelty Ads"
  description="Seeking marketing magic and web design wizardry? Novelty Ads offers full-stack digital marketing — SEO, paid ads, web design, Shopify, email marketing and Kickstarter."
  canonical="https://noveltyads.com/service/"
>

<section class="page-hero">
  <div class="container" style="position:relative;z-index:1;">
    <p class="page-hero__eyebrow" data-reveal="up">What We Offer</p>
    <h1 class="page-hero__title" data-reveal="up">Full Stack Marketing<br>For Growing Brands.</h1>
    <p class="page-hero__sub" data-reveal="up">You need a proactive, strategic, and customized marketing strategy to ensure your company is on a steady course towards success.</p>
    <div style="display:flex;gap:14px;flex-wrap:wrap;" data-reveal="up">
      <a href="/contact" class="btn btn-yellow btn-lg">Start Free Trial</a>
      <a href="/case-studies" class="btn btn-outline-white btn-lg">See Our Work</a>
    </div>
  </div>
</section>

<section style="padding:120px 0;background:#0A0A0A;">
  <div class="container">
    <div style="text-align:center;margin-bottom:64px;">
      <p class="section-eyebrow eyebrow-light" data-reveal="up">Our Services</p>
      <h2 class="section-title title-light" style="margin-top:14px;" data-reveal="up">We offer the attention to detail<br>your business deserves.</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;" data-stagger>
      <a href="/web-design" class="svc-card svc-yellow">
        <div class="svc-card__icon">🎨</div>
        <h3 class="svc-card__title">Web Design &amp; Development</h3>
        <p class="svc-card__desc">Modern, responsive websites built to convert visitors into customers. WordPress, Webflow, Shopify, and custom builds.</p>
        <span class="svc-card__cta">Explore <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
      </a>
      <a href="/seo" class="svc-card svc-blue">
        <div class="svc-card__icon">🔍</div>
        <h3 class="svc-card__title">SEO Services</h3>
        <p class="svc-card__desc">On-page, off-page, and technical SEO. We grow your organic visibility so customers find you first.</p>
        <span class="svc-card__cta">Explore <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
      </a>
      <a href="/paid-ads" class="svc-card svc-orange">
        <div class="svc-card__icon">⚡</div>
        <h3 class="svc-card__title">Paid Ads</h3>
        <p class="svc-card__desc">Meta, Google, TikTok — data-driven campaigns that maximize ROAS and generate predictable, scalable revenue.</p>
        <span class="svc-card__cta">Explore <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
      </a>
      <a href="/kickstarter" class="svc-card svc-green">
        <div class="svc-card__icon">🚀</div>
        <h3 class="svc-card__title">Kickstarter &amp; Crowdfunding</h3>
        <p class="svc-card__desc">Pre-launch marketing, launch campaigns, consulting — we've helped crowdfund over $600k for creative projects.</p>
        <span class="svc-card__cta">Explore <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
      </a>
      <a href="/shopify" class="svc-card svc-purple">
        <div class="svc-card__icon">🛍️</div>
        <h3 class="svc-card__title">Shopify Development</h3>
        <p class="svc-card__desc">Custom Shopify & Shopify Plus stores. Migrations from Webflow, Wix, Squarespace. Headless eCommerce.</p>
        <span class="svc-card__cta">Explore <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
      </a>
      <a href="/email-marketing" class="svc-card svc-glass">
        <div class="svc-card__icon">📧</div>
        <h3 class="svc-card__title">Email Marketing</h3>
        <p class="svc-card__desc">Klaviyo, Mailchimp, automated sequences. Drive repeat revenue and increase customer lifetime value.</p>
        <span class="svc-card__cta">Explore <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
      </a>
    </div>
  </div>
</section>

<section style="padding:120px 0;background:#EFEDE8;">
  <div class="container">
    <div style="text-align:center;max-width:640px;margin:0 auto 64px;">
      <p class="section-eyebrow eyebrow-dark" data-reveal="up">Why Choose Us</p>
      <h2 class="section-title title-dark" style="margin-top:14px;" data-reveal="up">Full stack marketing means<br>we do it all — together.</h2>
    </div>
    <div class="stats-grid" data-reveal="scale">
      <div class="stat-cell">
        <div class="stat-cell__num"><span class="js-counter" data-to="40" data-suffix="+">40+</span></div>
        <div class="stat-cell__label">Clients Served</div>
      </div>
      <div class="stat-cell">
        <div class="stat-cell__num"><span class="js-counter" data-to="1" data-suffix="M+">1M+</span></div>
        <div class="stat-cell__label">Website Visitors Generated</div>
      </div>
      <div class="stat-cell">
        <div class="stat-cell__num"><span class="js-counter" data-to="1" data-suffix="M+">1M+</span></div>
        <div class="stat-cell__label">Ad Spend Managed</div>
      </div>
      <div class="stat-cell">
        <div class="stat-cell__num"><span class="js-counter" data-to="5" data-suffix="★">5★</span></div>
        <div class="stat-cell__label">Average Client Rating</div>
      </div>
    </div>
  </div>
</section>

<section style="padding:100px 0 120px;background:#EFEDE8;">
  <div class="container">
    <div class="cta-box" data-reveal="scale">
      <p class="section-eyebrow" style="color:rgba(255,255,255,0.3);margin-bottom:14px;">Ready to Start?</p>
      <h2 class="cta-title">7-day risk-free trial.<br>No contracts.</h2>
      <p class="cta-sub">We're profitable if you're profitable. Let's grow together.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn-yellow btn-xl">Book Free Discovery Call →</a>
      </div>
    </div>
  </div>
</section>

</Layout>

<style>
  @media (max-width:768px) {
    div[style*="grid-template-columns:repeat(3,1fr)"] { grid-template-columns: 1fr !important; }
  }
</style>
