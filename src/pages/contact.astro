---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Contact | Novelty Ads"
  description="Got questions about digital marketing? Contact Novelty Ads and let's start growing your business. Free discovery call — no obligations."
  canonical="https://noveltyads.com/contact/"
>

<section class="page-hero">
  <div class="container" style="position:relative;z-index:1;">
    <p class="page-hero__eyebrow" data-reveal="up">Get In Touch</p>
    <h1 class="page-hero__title" data-reveal="up">Got Questions?<br>Let's Talk.</h1>
    <p class="page-hero__sub" data-reveal="up">Sign up for a risk-free 7-day trial. No contracts, no commitments — just results.</p>
  </div>
</section>

<section style="padding:100px 0 120px;background:#F8F7F4;">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1.4fr;gap:64px;align-items:start;">

      <!-- Info -->
      <div data-reveal="up">
        <h2 style="font-size:28px;font-weight:800;letter-spacing:-0.02em;margin-bottom:32px;">Our Offices</h2>

        {[
          { flag: '🇺🇸', region: 'United States', loc: 'Delaware, USA', phone: '+1 (929) 242 1923', tel: '+19292421923' },
          { flag: '🇦🇪', region: 'UAE', loc: 'Deira, Dubai', phone: '+971 54 347 6261', tel: '+971543476261' },
          { flag: '🇦🇺', region: 'Australia', loc: 'Perth, WA', phone: '+971 54 347 6261', tel: '+971543476261' },
          { flag: '🇵🇰', region: 'Pakistan', loc: 'Faisalabad', phone: '+92 336 6563724', tel: '+923366563724' },
        ].map(o => (
          <div style="display:flex;gap:16px;padding:20px 0;border-bottom:1px solid rgba(0,0,0,0.08);">
            <div style="font-size:28px;flex-shrink:0;">{o.flag}</div>
            <div>
              <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6B6B6B;margin-bottom:3px;">{o.region}</div>
              <div style="font-size:16px;font-weight:600;margin-bottom:4px;">{o.loc}</div>
              <a href={`tel:${o.tel}`} style="font-size:14px;color:#3A5BF0;font-weight:500;">{o.phone}</a>
            </div>
          </div>
        ))}

        <div style="margin-top:40px;">
          <h3 style="font-size:16px;font-weight:700;margin-bottom:16px;">Follow Us</h3>
          <div style="display:flex;gap:10px;">
            <a href="https://www.facebook.com/noveltyadsagency" target="_blank" rel="noopener" class="btn btn-ghost" style="padding:10px 18px;">Facebook</a>
            <a href="https://www.instagram.com/novelty_ads/" target="_blank" rel="noopener" class="btn btn-ghost" style="padding:10px 18px;">Instagram</a>
            <a href="https://www.linkedin.com/company/noveltyads" target="_blank" rel="noopener" class="btn btn-ghost" style="padding:10px 18px;">LinkedIn</a>
          </div>
        </div>
      </div>

      <!-- Form -->
      <div data-reveal="right">
        <div style="background:#fff;border:1px solid rgba(0,0,0,0.08);border-radius:22px;padding:52px 44px;box-shadow:0 8px 40px rgba(0,0,0,0.06);">
          <h2 style="font-size:24px;font-weight:800;letter-spacing:-0.02em;margin-bottom:8px;">Send Us a Message</h2>
          <p style="font-size:14px;color:#6B6B6B;margin-bottom:36px;">We typically respond within 2–4 business hours.</p>

          <form action="https://formsubmit.co/hello@noveltyads.com" method="POST" style="display:flex;flex-direction:column;gap:20px;">
            <input type="hidden" name="_subject" value="New Contact from NovelyAds Website">
            <input type="hidden" name="_captcha" value="false">
            <input type="hidden" name="_next" value="https://noveltyads.com/contact/">

            <div>
              <label style="font-size:13px;font-weight:600;display:block;margin-bottom:7px;">Full Name *</label>
              <input type="text" name="name" required placeholder="John Smith"
                style="width:100%;padding:13px 16px;border:1.5px solid rgba(0,0,0,0.1);border-radius:12px;font-size:15px;font-family:inherit;outline:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#3A5BF0'" onblur="this.style.borderColor='rgba(0,0,0,0.1)'">
            </div>
            <div>
              <label style="font-size:13px;font-weight:600;display:block;margin-bottom:7px;">Email Address *</label>
              <input type="email" name="email" required placeholder="john@company.com"
                style="width:100%;padding:13px 16px;border:1.5px solid rgba(0,0,0,0.1);border-radius:12px;font-size:15px;font-family:inherit;outline:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#3A5BF0'" onblur="this.style.borderColor='rgba(0,0,0,0.1)'">
            </div>
            <div>
              <label style="font-size:13px;font-weight:600;display:block;margin-bottom:7px;">Service Interested In</label>
              <select name="service" style="width:100%;padding:13px 16px;border:1.5px solid rgba(0,0,0,0.1);border-radius:12px;font-size:15px;font-family:inherit;outline:none;background:#fff;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#3A5BF0'" onblur="this.style.borderColor='rgba(0,0,0,0.1)'">
                <option value="">Select a service...</option>
                <option>Web Design & Development</option>
                <option>SEO Services</option>
                <option>Paid Ads (Google / Meta / TikTok)</option>
                <option>Kickstarter / Crowdfunding</option>
                <option>Shopify Development</option>
                <option>Email Marketing</option>
                <option>Full-Stack Marketing</option>
              </select>
            </div>
            <div>
              <label style="font-size:13px;font-weight:600;display:block;margin-bottom:7px;">Message *</label>
              <textarea name="message" required rows="5" placeholder="Tell us about your project and goals..."
                style="width:100%;padding:13px 16px;border:1.5px solid rgba(0,0,0,0.1);border-radius:12px;font-size:15px;font-family:inherit;outline:none;resize:vertical;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#3A5BF0'" onblur="this.style.borderColor='rgba(0,0,0,0.1)'"></textarea>
            </div>
            <button type="submit" class="btn btn-dark" style="width:100%;padding:16px;font-size:16px;border-radius:12px;">
              Send Message →
            </button>
          </form>
        </div>
      </div>

    </div>
  </div>
</section>

</Layout>
<style>
  @media (max-width:768px) {
    div[style*="grid-template-columns:1fr 1.4fr"] { grid-template-columns: 1fr !important; }
  }
</style>
