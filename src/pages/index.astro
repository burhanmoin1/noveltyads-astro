<script>
  import gsap from 'gsap';

  const dash = document.getElementById('hero-dashboard');
  if (dash) {
    document.addEventListener('mousemove', (e) => {
      const xR = (e.clientX / window.innerWidth  - 0.5) * 2;
      const yR = (e.clientY / window.innerHeight - 0.5) * 2;
      gsap.to(dash, {
        rotateY: -6 + xR * 5,
        rotateX:  3 - yR * 3,
        duration: 1.2,
        ease: 'power1.out',
        overwrite: 'auto',
      });
    });
  }
</script>

