---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Full-Stack Digital Marketing Agency | Novelty Ads"
  description="Novelty Ads is the leading digital marketing agency founded in Delaware, United States. End-to-end marketing — web design, SEO, paid ads, Kickstarter and more. Trusted by 40+ organizations worldwide."
  canonical="https://noveltyads.com/"
>

<!-- ═══ HERO ═══ -->
<section class="hero" id="hero">
  <div class="blob blob-a"></div>
  <div class="blob blob-b"></div>
  <div class="blob blob-c"></div>

  <div class="container" style="position:relative;z-index:1;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;">

      <!-- Left -->
      <div>
        <div style="display:inline-flex;align-items:center;gap:8px;padding:6px 14px 6px 8px;background:rgba(255,255,255,0.7);border:1px solid rgba(0,0,0,0.08);border-radius:100px;font-size:13px;font-weight:500;margin-bottom:28px;backdrop-filter:blur(8px);" data-reveal="up">
          <span style="width:8px;height:8px;border-radius:50%;background:#05C870;flex-shrink:0;animation:dot-pulse 2s ease-in-out infinite;display:inline-block;"></span>
          Delaware · Dubai · Perth · Faisalabad
        </div>

        <h1 style="font-size:clamp(52px,6.5vw,90px);font-weight:800;line-height:1.04;letter-spacing:-0.035em;margin-bottom:24px;" data-reveal="up">
          A Full Stack<br>
          <span style="position:relative;display:inline-block;z-index:1;">
            <span style="position:absolute;bottom:6px;left:-2px;right:-2px;height:10px;background:#F5E642;border-radius:5px;z-index:-1;transform:skewX(-4deg);display:block;"></span>
            Digital
          </span> Marketing<br>Agency.
        </h1>

        <p style="font-size:18px;line-height:1.65;color:#6B6B6B;max-width:460px;margin-bottom:40px;" data-reveal="up">
          We drive real business results through end-to-end digital marketing — web design, SEO, paid ads, Kickstarter, Shopify, and more. Trusted by 40+ organizations worldwide.
        </p>

        <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap;margin-bottom:40px;" data-reveal="up">
          <a href="/contact" class="btn btn-dark btn-lg">Get Started Free</a>
          <a href="#home-case-studies" class="btn btn-ghost btn-lg">View Case Studies →</a>
        </div>

        <div style="display:flex;align-items:center;gap:12px;font-size:13px;color:#6B6B6B;margin-bottom:40px;" data-reveal="up">
          <div style="display:flex;">
            <img src="/images/jenna.jpg" alt="Jenna" style="width:32px;height:32px;border-radius:50%;border:2.5px solid #F8F7F4;object-fit:cover;display:block;">
            <img src="/images/gerardo.jpg" alt="Gerardo" style="width:32px;height:32px;border-radius:50%;border:2.5px solid #F8F7F4;object-fit:cover;display:block;margin-left:-8px;">
            <img src="/images/scott.jpg" alt="Scott" style="width:32px;height:32px;border-radius:50%;border:2.5px solid #F8F7F4;object-fit:cover;display:block;margin-left:-8px;">
            <img src="/images/micheal.jpg" alt="Micheal" style="width:32px;height:32px;border-radius:50%;border:2.5px solid #F8F7F4;object-fit:cover;display:block;margin-left:-8px;">
          </div>
          <span>Rated <strong>5/5</strong> by 40+ clients worldwide</span>
        </div>

        <div style="display:flex;gap:40px;padding-top:40px;border-top:1px solid rgba(0,0,0,0.08);" data-reveal="up">
          <div>
            <div style="font-size:38px;font-weight:800;letter-spacing:-0.03em;line-height:1;"><span class="js-counter" data-to="40" data-suffix="+">40+</span></div>
            <div style="font-size:13px;color:#6B6B6B;margin-top:4px;">Organizations Served</div>
          </div>
          <div>
            <div style="font-size:38px;font-weight:800;letter-spacing:-0.03em;line-height:1;"><span class="js-counter" data-to="5" data-suffix="yr">5yr</span></div>
            <div style="font-size:13px;color:#6B6B6B;margin-top:4px;">Years of Experience</div>
          </div>
          <div>
            <div style="font-size:38px;font-weight:800;letter-spacing:-0.03em;line-height:1;"><span class="js-counter" data-to="98" data-suffix="%">98%</span></div>
            <div style="font-size:13px;color:#6B6B6B;margin-top:4px;">Client Retention</div>
          </div>
        </div>
      </div>

      <!-- Right: CSS Dashboard -->
      <div data-reveal="right" style="display:block;">
        <div id="hero-dashboard" style="background:#fff;border-radius:20px;border:1px solid rgba(0,0,0,0.08);box-shadow:0 24px 60px rgba(0,0,0,0.12),0 8px 24px rgba(0,0,0,0.06);overflow:hidden;transform:perspective(1200px) rotateY(-6deg) rotateX(3deg);transition:transform 0.6s cubic-bezier(0.23,1,0.32,1);">
          <!-- Top bar -->
          <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 18px;background:#F8F7F4;border-bottom:1px solid rgba(0,0,0,0.06);">
            <div style="display:flex;gap:6px;">
              <div style="width:11px;height:11px;border-radius:50%;background:#FF5F57;"></div>
              <div style="width:11px;height:11px;border-radius:50%;background:#FEBC2E;"></div>
              <div style="width:11px;height:11px;border-radius:50%;background:#28C840;"></div>
            </div>
            <span style="font-size:12px;font-weight:600;color:#6B6B6B;">Campaign Dashboard · Q2 2026</span>
            <div style="display:flex;align-items:center;gap:5px;font-size:11px;font-weight:700;color:#05C870;background:rgba(5,200,112,0.1);padding:3px 9px;border-radius:100px;">
              <span style="width:6px;height:6px;border-radius:50%;background:#05C870;display:inline-block;animation:dot-pulse 2s infinite;"></span>Live
            </div>
          </div>
          <!-- KPIs -->
          <div style="display:grid;grid-template-columns:repeat(3,1fr);">
            <div style="padding:18px 16px;text-align:center;background:#008080;color:#fff;">
              <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;opacity:0.8;margin-bottom:4px;">ROAS</div>
              <div style="font-size:24px;font-weight:800;letter-spacing:-0.04em;line-height:1;">4.8×</div>
              <div style="font-size:11px;font-weight:600;margin-top:4px;opacity:0.9;">↑ 23%</div>
            </div>
            <div style="padding:18px 16px;text-align:center;background:#1A1A1A;color:#fff;">
              <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;opacity:0.8;margin-bottom:4px;">Revenue</div>
              <div style="font-size:24px;font-weight:800;letter-spacing:-0.04em;line-height:1;">$84k</div>
              <div style="font-size:11px;font-weight:600;margin-top:4px;opacity:0.9;">↑ 41%</div>
            </div>
            <div style="padding:18px 16px;text-align:center;background:#E5E7EB;color:#1A1A1A;">
              <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;opacity:0.6;margin-bottom:4px;">Leads</div>
              <div style="font-size:24px;font-weight:800;letter-spacing:-0.04em;line-height:1;">2,340</div>
              <div style="font-size:11px;font-weight:600;margin-top:4px;color:#059669;">↑ 18%</div>
            </div>
          </div>
          <!-- Sparkline -->
          <div style="padding:18px 18px 8px;">
            <div style="font-size:11px;font-weight:600;color:#6B6B6B;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:10px;">Organic Traffic — Last 30 Days</div>
            <svg viewBox="0 0 320 80" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:auto;display:block;">
              <defs>
                <linearGradient id="chartGrad" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#008080" stop-opacity="0.2"/>
                  <stop offset="100%" stop-color="#008080" stop-opacity="0"/>
                </linearGradient>
              </defs>
              <path d="M0 72 C20 68 35 60 55 55 C75 50 90 52 110 44 C130 36 145 30 165 22 C185 14 200 18 220 12 C240 6 260 8 280 4 C295 1 310 2 320 0 L320 80 L0 80 Z" fill="url(#chartGrad)"/>
              <path d="M0 72 C20 68 35 60 55 55 C75 50 90 52 110 44 C130 36 145 30 165 22 C185 14 200 18 220 12 C240 6 260 8 280 4 C295 1 310 2 320 0" stroke="#008080" stroke-width="2.5" stroke-linecap="round"/>
              <circle cx="320" cy="0" r="4" fill="#008080"/>
            </svg>
          </div>
          <!-- Service tiles -->
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;padding:14px 16px 18px;background:rgba(249,249,247,0.5);">
            <a href="/web-design" style="background:#fff;color:#1A1A1A;border:1px solid #e5e7eb;border-radius:12px;padding:12px 10px;display:flex;flex-direction:column;align-items:center;gap:6px;text-decoration:none;transition:transform 0.2s;">
              <div style="width:32px;height:32px;border-radius:8px;background:rgba(0,128,128,0.1);display:flex;align-items:center;justify-content:center;"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#008080" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg></div>
              <span style="font-size:11px;font-weight:700;text-align:center;line-height:1.2;">Web Design</span>
            </a>
            <a href="/seo" style="background:#008080;color:#fff;border-radius:12px;padding:12px 10px;display:flex;flex-direction:column;align-items:center;gap:6px;text-decoration:none;transition:transform 0.2s;">
              <div style="width:32px;height:32px;border-radius:8px;background:rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" x2="16.65" y1="21" y2="16.65"/></svg></div>
              <span style="font-size:11px;font-weight:700;text-align:center;line-height:1.2;">SEO</span>
            </a>
            <a href="/paid-ads" style="background:#fff;color:#1A1A1A;border:1px solid #e5e7eb;border-radius:12px;padding:12px 10px;display:flex;flex-direction:column;align-items:center;gap:6px;text-decoration:none;transition:transform 0.2s;">
              <div style="width:32px;height:32px;border-radius:8px;background:rgba(26,26,26,0.05);display:flex;align-items:center;justify-content:center;"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></div>
              <span style="font-size:11px;font-weight:700;text-align:center;line-height:1.2;">Paid Ads</span>
            </a>
            <a href="/kickstarter" style="background:#E5E7EB;color:#1A1A1A;border-radius:12px;padding:12px 10px;display:flex;flex-direction:column;align-items:center;gap:6px;text-decoration:none;transition:transform 0.2s;">
              <div style="width:32px;height:32px;border-radius:8px;background:#fff;display:flex;align-items:center;justify-content:center;"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#008080" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg></div>
              <span style="font-size:11px;font-weight:700;text-align:center;line-height:1.2;">Kickstarter</span>
            </a>
            <a href="/shopify" style="background:#fff;color:#1A1A1A;border:1px solid #e5e7eb;border-radius:12px;padding:12px 10px;display:flex;flex-direction:column;align-items:center;gap:6px;text-decoration:none;transition:transform 0.2s;">
              <div style="width:32px;height:32px;border-radius:8px;background:rgba(26,26,26,0.05);display:flex;align-items:center;justify-content:center;"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg></div>
              <span style="font-size:11px;font-weight:700;text-align:center;line-height:1.2;">Shopify</span>
            </a>
            <a href="/email-marketing" style="background:#1A1A1A;color:#fff;border-radius:12px;padding:12px 10px;display:flex;flex-direction:column;align-items:center;gap:6px;text-decoration:none;transition:transform 0.2s;">
              <div style="width:32px;height:32px;border-radius:8px;background:rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg></div>
              <span style="font-size:11px;font-weight:700;text-align:center;line-height:1.2;">Email Mktg</span>
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ═══ CLIENTS LOGO STRIP ═══ -->
<div style="padding:52px 0;border-top:1px solid rgba(0,0,0,0.08);">
  <p style="text-align:center;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.16em;color:#aaa;margin-bottom:40px;">Organizations that trust Novelty Ads</p>
  <div class="marquee-outer">
    <div class="marquee-track">
      <!-- Set 1 -->
      <div class="marquee-item"><img src="/images/clients/stress-factory.png" alt="Stress Factory Comedy Club" height="38" loading="lazy" /></div>
      <div class="marquee-item"><img src="/images/clients/bury-hatchet.png" alt="Bury the Hatchet" height="38" loading="lazy" /></div>
      <div class="marquee-item"><img src="/images/clients/amazing-escape-room.png" alt="Amazing Escape Room" height="38" loading="lazy" /></div>
      <div class="marquee-item"><img src="/images/clients/malise-marine.png" alt="Friday's Malise Marine" height="38" loading="lazy" /></div>
      <div class="marquee-item"><img src="/images/clients/keystone.png" alt="Keystone Contracting" height="38" loading="lazy" /></div>
      <div class="marquee-item"><img src="/images/clients/pine-ridge.png" alt="Pine Ridge Dude Ranch" height="38" loading="lazy" /></div>
      <!-- Set 2 — duplicate for seamless infinite loop -->
      <div class="marquee-item"><img src="/images/clients/stress-factory.png" alt="Stress Factory Comedy Club" height="38" loading="lazy" /></div>
      <div class="marquee-item"><img src="/images/clients/bury-hatchet.png" alt="Bury the Hatchet" height="38" loading="lazy" /></div>
      <div class="marquee-item"><img src="/images/clients/amazing-escape-room.png" alt="Amazing Escape Room" height="38" loading="lazy" /></div>
      <div class="marquee-item"><img src="/images/clients/malise-marine.png" alt="Friday's Malise Marine" height="38" loading="lazy" /></div>
      <div class="marquee-item"><img src="/images/clients/keystone.png" alt="Keystone Contracting" height="38" loading="lazy" /></div>
      <div class="marquee-item"><img src="/images/clients/pine-ridge.png" alt="Pine Ridge Dude Ranch" height="38" loading="lazy" /></div>
    </div>
  </div>
</div>

<!-- Section gradient ramp: cream → black -->
<div aria-hidden="true" style="height:90px;background:linear-gradient(180deg,#F8F7F4 0%,#0A0A0A 100%);display:block;"></div>

<!-- ═══ SERVICES ═══ -->
<section style="padding:60px 0 120px;background:#0A0A0A;" id="services">
  <div class="container">
    <div class="section-header">
      <div class="section-header-left">
        <p class="section-eyebrow eyebrow-light" data-reveal="up">What We Do</p>
        <h2 class="section-title title-light" style="margin-top:14px;" data-reveal="up">Everything you need<br>to grow online.</h2>
      </div>
      <p class="section-sub sub-light" style="max-width:480px;" data-reveal="up">From first impression to final conversion — we cover every touchpoint in your customer's journey.</p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;" data-stagger>
      <a href="/web-design" class="svc-card svc-yellow">
        <div class="svc-card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg></div>
        <h3 class="svc-card__title">Web Design &amp; Development</h3>
        <p class="svc-card__desc">Beautiful, conversion-optimised websites that match your brand's mission and vision.</p>
        <span class="svc-card__cta">Learn more <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
      </a>
      <a href="/seo" class="svc-card svc-blue">
        <div class="svc-card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg></div>
        <h3 class="svc-card__title">SEO Services</h3>
        <p class="svc-card__desc">Dominate search rankings with proven full-spectrum SEO that compounds over time.</p>
        <span class="svc-card__cta">Learn more <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
      </a>
      <a href="/paid-ads" class="svc-card svc-orange">
        <div class="svc-card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></div>
        <h3 class="svc-card__title">Paid Ads</h3>
        <p class="svc-card__desc">Meta, Google, TikTok — high-ROAS campaigns that turn ad spend into predictable revenue.</p>
        <span class="svc-card__cta">Learn more <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
      </a>
      <a href="/kickstarter" class="svc-card svc-green">
        <div class="svc-card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg></div>
        <h3 class="svc-card__title">Kickstarter &amp; Crowdfunding</h3>
        <p class="svc-card__desc">We've helped crowdfund over $600k. Specialised marketing for campaigns that exceed goals.</p>
        <span class="svc-card__cta">Learn more <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
      </a>
      <a href="/shopify" class="svc-card svc-purple">
        <div class="svc-card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" x2="21" y1="6" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg></div>
        <h3 class="svc-card__title">Shopify Development</h3>
        <p class="svc-card__desc">Custom Shopify stores built for scale. Migrations, custom builds, and theme development.</p>
        <span class="svc-card__cta">Learn more <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
      </a>
      <a href="/email-marketing" class="svc-card svc-glass">
        <div class="svc-card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg></div>
        <h3 class="svc-card__title">Email Marketing</h3>
        <p class="svc-card__desc">Automated sequences and retention campaigns that keep customers coming back month over month.</p>
        <span class="svc-card__cta">Learn more <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
      </a>
    </div>
  </div>
</section>

<!-- ═══ STATS ═══ -->
<section style="padding:120px 0;background:#EFEDE8;">
  <div class="container">
    <div style="text-align:center;margin-bottom:64px;">
      <p class="section-eyebrow eyebrow-dark" data-reveal="up">By The Numbers</p>
      <h2 class="section-title title-dark" style="margin-top:14px;" data-reveal="up">Results that speak<br>for themselves.</h2>
    </div>
