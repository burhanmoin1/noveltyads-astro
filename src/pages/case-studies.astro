---
import Layout from '../layouts/Layout.astro';

const studies = [
  {
    name: 'Open Door Valet',
    type: 'Web Design',
    service: 'WordPress Website',
    img: '/images/case-studies/open-door-valet.png',
    accent: '#0A0A0A',
    desc: 'Complete brand refresh and high-performance WordPress site for a premium valet parking service in the USA.',
  },
  {
    name: 'The Next Step Program',
    type: 'Web Design',
    service: 'WordPress Website',
    img: '/images/case-studies/next-step-program.png',
    accent: '#3A5BF0',
    desc: 'Custom WordPress site for a career development programme. CTA-optimised landing pages driving lead generation.',
  },
  {
    name: 'Chic Liquidation',
    type: 'E-Commerce',
    service: 'Shopify Store',
    img: '/images/case-studies/chic-liquidation.png',
    accent: '#FF5CA8',
    desc: 'Full Shopify store build for a fashion liquidation brand. Custom theme, product filtering, and conversion-focused UX.',
  },
  {
    name: 'Espinal Consultores',
    type: 'Web Design',
    service: 'WordPress Website',
    img: '/images/case-studies/espinal-consultores.png',
    accent: '#05C870',
    desc: 'Professional consulting firm website with multilingual support and appointment booking integration.',
  },
  {
    name: 'Neros Foods',
    type: 'E-Commerce',
    service: 'Shopify + Web Design',
    img: '/images/case-studies/neros-foods.png',
    accent: '#FF6B35',
    desc: 'Food brand e-commerce site with rich storytelling, recipe content, and Shopify checkout optimisation.',
  },
  {
    name: 'Locobebe',
    type: 'Web Design',
    service: 'Brand Website',
    img: '/images/case-studies/locobebe.png',
    accent: '#9B5DE5',
    desc: 'Kids product brand website with playful design system, product showcase, and lead capture forms.',
  },
];
---
<Layout
  title="Case Studies | Novelty Ads"
  description="Explore Novelty Ads case studies — web design, Shopify, and digital marketing results for clients across the USA, UAE, Australia, and Pakistan."
  canonical="https://noveltyads.com/case-studies/"
>

<section class="page-hero">
  <div class="container" style="position:relative;z-index:1;">
    <p class="page-hero__eyebrow" data-reveal="up">Case Studies</p>
    <h1 class="page-hero__title" data-reveal="up">Real clients.<br>Real results.</h1>
    <p class="page-hero__sub" data-reveal="up">Explore how we've helped businesses across the globe build stunning websites, launch campaigns, and grow their revenue through full-stack digital marketing.</p>
  </div>
</section>

<!-- ── Grid ── -->
<section style="padding:100px 0 120px;background:#F8F7F4;">
  <div class="container">
    <div class="cs-grid" data-stagger>
      {studies.map(s => (
        <article class="cs-card">
          <!-- Image -->
          <div class="cs-card__media">
            <img
              src={s.img}
              alt={`${s.name} — Novelty Ads Case Study`}
              loading="lazy"
              decoding="async"
            />
            <!-- Badge -->
            <span class="cs-card__badge" style={`background:${s.accent};`}>{s.type}</span>
          </div>
          <!-- Body -->
          <div class="cs-card__body">
            <p class="cs-card__service">{s.service}</p>
            <h3 class="cs-card__title">{s.name}</h3>
            <p class="cs-card__desc">{s.desc}</p>
            <a href="/contact" class="cs-card__link">
              Start a similar project
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ── CTA ── -->
<section class="cta-section" style="padding:100px 0 120px;background:#F8F7F4;">
  <div class="container">
    <div class="cta-box" data-reveal="scale">
      <p class="section-eyebrow" style="color:rgba(255,255,255,0.3);margin-bottom:14px;">Your Turn</p>
      <h2 class="cta-title">Want results like these?<br>Let's talk.</h2>
      <p class="cta-sub">Book a free discovery call and we'll show you exactly what we can do for your business.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn-yellow btn-xl">Book Free Call →</a>
      </div>
    </div>
  </div>
</section>

</Layout>

<style>
/* ── Case study grid ── */
.cs-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
}

/* Card shell */
.cs-card {
  background: #fff;
  border-radius: 20px;
  overflow: hidden;
  border: 1px solid rgba(0,0,0,0.06);
  transition: transform 0.35s cubic-bezier(0.23,1,0.32,1), box-shadow 0.35s;
}
.cs-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 28px 64px rgba(0,0,0,0.11);
}

/* Image area */
.cs-card__media {
  position: relative;
  overflow: hidden;
  aspect-ratio: 16 / 10;
  background: #eee;
}
.cs-card__media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s cubic-bezier(0.23,1,0.32,1);
}
.cs-card:hover .cs-card__media img {
  transform: scale(1.04);
}

/* Badge */
.cs-card__badge {
  position: absolute;
  top: 16px;
  left: 16px;
  color: #fff;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  padding: 5px 13px;
  border-radius: 100px;
  pointer-events: none;
}

/* Body */
.cs-card__body {
  padding: 28px 30px 32px;
}
.cs-card__service {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: #aaa;
  margin-bottom: 8px;
}
.cs-card__title {
  font-size: 22px;
  font-weight: 800;
  letter-spacing: -0.025em;
  color: #0A0A0A;
  margin-bottom: 10px;
  line-height: 1.15;
}
.cs-card__desc {
  font-size: 14px;
  line-height: 1.65;
  color: #6B6B6B;
  margin-bottom: 22px;
}
.cs-card__link {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 13px;
  font-weight: 700;
  color: #0A0A0A;
  text-decoration: none;
  transition: gap 0.2s;
}
.cs-card__link:hover { gap: 12px; }
.cs-card__link svg { flex-shrink: 0; }

/* Mobile */
@media (max-width: 768px) {
  .cs-grid { grid-template-columns: 1fr; }
  .cs-card__media { aspect-ratio: 16 / 10; }
}
</style>
