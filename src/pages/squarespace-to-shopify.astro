---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Squarespace to Shopify Migration | Novelty Ads"
  description="Migrate from Squarespace to Shopify with Novelty Ads. Full migration with zero data loss, SEO preservation, and custom Shopify theme development."
  canonical="https://noveltyads.com/squarespace-to-shopify/"
>
<section class="page-hero">
  <div class="container" style="position:relative;z-index:1;">
    <p class="page-hero__eyebrow" data-reveal="up">Migration Service</p>
    <h1 class="page-hero__title" data-reveal="up">Squarespace → Shopify<br>Migration.</h1>
    <p class="page-hero__sub" data-reveal="up">Squarespace is beautiful for portfolios — but Shopify is built to sell. Let us migrate your entire store seamlessly, with no data loss and full SEO preservation.</p>
    <div style="display:flex;gap:14px;flex-wrap:wrap;" data-reveal="up">
      <a href="/contact" class="btn btn-yellow btn-lg">Start Migration</a>
    </div>
  </div>
</section>
<section style="padding:120px 0;background:#F8F7F4;">
  <div class="container">
    <div class="stats-grid" data-reveal="scale">
      <div class="stat-cell"><div class="stat-cell__num">100%</div><div class="stat-cell__label">Data preservation</div></div>
      <div class="stat-cell"><div class="stat-cell__num">0</div><div class="stat-cell__label">Downtime during migration</div></div>
      <div class="stat-cell"><div class="stat-cell__num">301</div><div class="stat-cell__label">Redirects for all old URLs</div></div>
      <div class="stat-cell"><div class="stat-cell__num">Fast</div><div class="stat-cell__label">Shopify CDN performance</div></div>
    </div>
  </div>
</section>
<section style="padding:100px 0 120px;background:#F8F7F4;">
  <div class="container">
    <div class="cta-box" data-reveal="scale">
      <h2 class="cta-title">Ready to move from<br>Squarespace to Shopify?</h2>
      <p class="cta-sub">Get a free migration consultation and quote from our expert Shopify team.</p>
      <div class="cta-actions"><a href="/contact" class="btn btn-yellow btn-xl">Get Free Quote →</a></div>
    </div>
  </div>
</section>
</Layout>
