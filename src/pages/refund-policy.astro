---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Refund & Returns Policy | Novelty Ads" description="Novelty Ads Refund and Returns Policy." canonical="https://noveltyads.com/refund_returns/" noindex={true}>
<section class="page-hero" style="padding:100px 0 60px;">
  <div class="container" style="position:relative;z-index:1;">
    <h1 class="page-hero__title" data-reveal="up">Refund &amp; Returns Policy</h1>
    <p class="page-hero__sub" data-reveal="up">Last updated: January 2025</p>
  </div>
</section>
<section style="padding:60px 0 120px;background:#F8F7F4;">
  <div class="container">
    <div style="max-width:740px;margin:0 auto;font-size:16px;line-height:1.8;color:#444;" data-reveal="up">
      <p style="margin-bottom:20px;">We offer a 7-day risk-free trial for new clients. If you're not satisfied within the first 7 days, you may cancel with no charge.</p>
      <h2 style="font-size:22px;font-weight:700;margin:36px 0 12px;color:#0A0A0A;">Monthly Retainers</h2>
      <p style="margin-bottom:20px;">Monthly retainer services may be cancelled with 30 days' written notice. No refunds are issued for partial months of service already delivered.</p>
      <h2 style="font-size:22px;font-weight:700;margin:36px 0 12px;color:#0A0A0A;">Project-Based Work</h2>
      <p style="margin-bottom:20px;">For fixed-price projects, refunds are available before work begins. Once a project milestone is delivered and approved, that portion is non-refundable.</p>
      <h2 style="font-size:22px;font-weight:700;margin:36px 0 12px;color:#0A0A0A;">Questions?</h2>
      <p><a href="/contact" style="color:#3A5BF0;font-weight:600;">Contact our team</a> and we'll work with you to find a fair resolution.</p>
    </div>
  </div>
</section>
</Layout>
