  <div class="container">

    <!-- ── Hero CTA row ── -->
    <div class="footer-hero">
      <div>
        <p class="footer-over">Ready when you are.</p>
        <h2 class="footer-hl">Let's build something<br><span class="footer-hl-em">remarkable.</span></h2>
      </div>
      <div class="footer-hero-right">
        <a href="/contact" class="btn btn-teal btn-lg">Start a Project →</a>
